---
import "../global.css";

const {
  header,
  subheader,
  lang,
  displayProject,
  description,
  image,
  isHome,
  noindex,
} = Astro.props;

const segments = ["Tonda Kučera", header, subheader].filter(Boolean);
const title = segments.join(" / ");

const ogImage = new URL(image ?? "/android-chrome-512x512.png", Astro.site)
  .href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const desc = description ?? "Tonda Kučera - programátor, grafik a kreativec.";
---

<html lang={lang} class="bg-[#F7F4F0] dark:bg-[#111116] dark:text-neutral-50">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tonda Kučera" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="cs_CZ" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    {
      isHome && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Person",
            name: "Tonda Kučera",
            url: "https://kucera.dev",
            email: "mailto:tonda@kucera.dev",
            jobTitle: "Programátor, grafik a kreativec",
            sameAs: ["https://github.com/Limit-sest"],
          })}
        />
      )
    }
  </head>
  <body class="border-accent relative mx-auto mb-8 max-w-2xl border">
    <header class="">
      <div
        class="bg-accent flex items-center-safe justify-between gap-2 px-6 py-3"
      >
        <a
          class="font-display text-white hover:underline"
          href="https://kucera.dev">Tonda Kučera</a
        >
        <div class="h-1 flex-1 border-b border-b-white"></div>
        <h1 class="font-display text-white">
          {header}{subheader != null && " / "}{subheader != null && subheader}
        </h1>
      </div>
    </header>

    <nav class="sticky top-0 z-20 bg-[#F7F4F0] dark:bg-[#111116]">
      <div class="border-b-accent flex border-b px-6 py-3">
        <div class="flex flex-1 items-center-safe justify-evenly gap-2">
          <a
            href="/"
            class:list={[
              "hover:text-accent hover:underline",
              { "font-display": header === "O mně" },
            ]}>O mně</a
          >
          <a
            href="/projects"
            class:list={[
              "hover:text-accent hover:underline",
              { "font-display": header === "Projekty" },
            ]}>Projekty</a
          >
          <a
            href="/graphics"
            class:list={[
              "hover:text-accent hover:underline",
              { "font-display": header === "Grafika" },
            ]}>Grafika</a
          >
          <a
            href="/photos"
            class:list={[
              "hover:text-accent hover:underline",
              { "font-display": header === "Fotky" },
            ]}>Fotky</a
          >
        </div>
      </div>
      {
        displayProject && (
          <a
            href="/projects"
            class="border-accent hover:text-accent block w-full border-b py-3 text-center font-medium transition-all duration-100 ease-in-out hover:underline"
          >
            ← {lang == "cs" ? "Zpátky na projekty" : "Back to projects"}
          </a>
        )
      }
    </nav>

    <main class="p-8">
      <slot />
    </main>
    <footer>
      <div
        class="border-t-accent text-accent flex items-center-safe justify-between gap-2 border-t px-6 py-3 font-medium"
      >
        <p>&copy;Tonda Kučera 2025–26</p>
        <div class="border-b-accent h-1 flex-1 border-b"></div>
        <a href="/credits" class="underline">Credits</a>
      </div>
    </footer>
  </body>
</html>
