---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.priority - a.data.priority,
);
---

<Layout
  header="Projekty"
  lang="cs"
  description="Seznam projektů, které jsem vytvořil nebo se na nich podílel."
>
  <div class="flex flex-col gap-4">
    {
      projects.map((project) => (
        <div class="group flex flex-col overflow-hidden rounded-3xl">
          <article class="z-10 aspect-3/2 overflow-hidden rounded-b-3xl">
            <Picture
              src={project.data.image}
              alt={project.data.name}
              class="-z-10 h-full"
            />
          </article>
          <header class="flex flex-col p-4 pt-3">
            <div class="flex items-baseline justify-between">
              <h2 class="font-display text-xl">{project.data.name}</h2>
              <p class="font-display text-sm">{project.data.year}</p>
            </div>
            <p class="text-sm font-medium">{project.data.description}</p>
          </header>
        </div>
      ))
    }
  </div>
</Layout>
