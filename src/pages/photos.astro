---
import Layout from "../layouts/Layout.astro";
import Lightbox from "../components/Lightbox.astro";
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

const photos = (await getCollection("photos")).sort(
  (a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime(),
);

const monthFmt = new Intl.DateTimeFormat("cs-CZ", {
  month: "long",
  timeZone: "UTC",
});
function formatDateRange(first: Date, last: Date) {
  const fy = first.getUTCFullYear(),
    ly = last.getUTCFullYear();
  const fm = first.getUTCMonth(),
    lm = last.getUTCMonth();
  if (fy === ly && fm === lm) return `${monthFmt.format(last)} ${ly}`;
  if (fy === ly)
    return `${monthFmt.format(first)}–${monthFmt.format(last)} ${ly}`;
  return `${monthFmt.format(first)} ${fy} – ${monthFmt.format(last)} ${ly}`;
}
---

<Layout
  header="Fotky"
  lang="cs"
  description="Přehled fotek které jsem nafotil."
>
  {
    photos.map((album, albumIndex) => (
      <section class="mb-16 flex w-full flex-col" data-album={albumIndex}>
        <div class="border-accent mb-2 flex items-baseline justify-between border-b pb-0.5">
          <h2
            id={album.id}
            class="text-accent font-display scroll-mt-24 text-2xl"
          >
            {album.data.name}
          </h2>
          <p class="text-accent text-xl">
            {formatDateRange(album.data.firstDate, album.data.lastDate)}
          </p>
        </div>
        <div class="flex gap-2">
          <div class="flex flex-1 flex-col gap-2">
            {album.data.images
              ?.filter((_, i) => i % 2 === 0)
              .map((image, fi) => {
                const imageIndex = fi * 2;
                return (
                  <button
                    type="button"
                    class="lightbox-trigger block w-full cursor-pointer"
                    data-album={albumIndex}
                    data-index={imageIndex}
                    data-src={image.path.src}
                  >
                    <Picture
                      src={image.path}
                      alt={`${album.data.name} – ${imageIndex + 1}`}
                      class="block w-full rounded-3xl"
                      widths={[200, 400, 608, 1216]}
                      sizes="(min-width: 640px) 50vw, calc(100vw - 66px)"
                      formats={["avif", "webp"]}
                      loading="lazy"
                    />
                  </button>
                );
              })}
          </div>
          <div class="flex flex-1 flex-col gap-2">
            {album.data.images
              ?.filter((_, i) => i % 2 === 1)
              .map((image, fi) => {
                const imageIndex = fi * 2 + 1;
                return (
                  <button
                    type="button"
                    class="lightbox-trigger block w-full cursor-pointer"
                    data-album={albumIndex}
                    data-index={imageIndex}
                    data-src={image.path.src}
                  >
                    <Picture
                      src={image.path}
                      alt={`${album.data.name} – ${imageIndex + 1}`}
                      class="block w-full rounded-3xl"
                      widths={[200, 400, 608, 1216]}
                      sizes="(min-width: 640px) 50vw, calc(100vw - 66px)"
                      formats={["avif", "webp"]}
                      loading="lazy"
                    />
                  </button>
                );
              })}
          </div>
        </div>
      </section>
    ))
  }

  <Lightbox />
</Layout>
