---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

const photos = await getCollection("photos");
---

<Layout
  header="Fotky"
  lang="cs"
  description="Přehled fotek které jsem nafotil."
>
  {
    photos.map((album, albumIndex) => (
      <section class="flex w-full flex-col" data-album={albumIndex}>
        <div class="border-accent mb-2 flex items-baseline justify-between border-b pb-0.5">
          <h2 class="text-accent font-display text-2xl">{album.data.name}</h2>
          <p class="text-accent text-xl">{album.data.meta}</p>
        </div>
        <div class="columns-1 gap-2 sm:columns-2">
          {album.data.images?.map((image, imageIndex) => {
            return (
              <button
                type="button"
                class="lightbox-trigger mb-2 block w-full cursor-pointer break-inside-avoid"
                data-album={albumIndex}
                data-index={imageIndex}
                data-src={image.path.src}
              >
                <Picture
                  src={image.path}
                  alt=""
                  class="block w-full rounded-3xl"
                  widths={[200, 400, 608, 1216]}
                  sizes="(min-width: 640px) 50vw, calc(100vw - 66px)"
                  formats={["avif", "webp"]}
                  loading="lazy"
                />
              </button>
            );
          })}
        </div>
      </section>
    ))
  }

  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90"
  >
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 cursor-pointer text-4xl text-white"
      aria-label="Zavřít">&times;</button
    >
    <button
      id="lightbox-prev"
      class="absolute left-4 cursor-pointer text-4xl text-white"
      aria-label="Předchozí">&#8249;</button
    >
    <img
      id="lightbox-img"
      class="max-h-[90vh] max-w-[90vw] object-contain"
      alt=""
    />
    <button
      id="lightbox-next"
      class="absolute right-4 cursor-pointer text-4xl text-white"
      aria-label="Následující">&#8250;</button
    >
  </div>
</Layout>

<script>
  const lightbox = document.getElementById("lightbox")!;
  const lightboxImg = document.getElementById(
    "lightbox-img",
  ) as HTMLImageElement;
  const triggers =
    document.querySelectorAll<HTMLButtonElement>(".lightbox-trigger");

  // Build album data from triggers
  const albums = new Map<number, string[]>();
  triggers.forEach((t) => {
    const albumIdx = Number(t.dataset.album);
    if (!albums.has(albumIdx)) albums.set(albumIdx, []);
    albums.get(albumIdx)![Number(t.dataset.index)] = t.dataset.src!;
  });

  let currentAlbum = 0;
  let currentIndex = 0;

  function show(album: number, index: number) {
    const images = albums.get(album);
    if (!images) return;
    currentAlbum = album;
    currentIndex = ((index % images.length) + images.length) % images.length;
    lightboxImg.src = images[currentIndex];
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function hide() {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
  }

  function navigate(delta: number) {
    const images = albums.get(currentAlbum);
    if (!images) return;
    show(currentAlbum, currentIndex + delta);
  }

  triggers.forEach((t) => {
    t.addEventListener("click", () => {
      show(Number(t.dataset.album), Number(t.dataset.index));
    });
  });

  document.getElementById("lightbox-close")!.addEventListener("click", hide);
  document
    .getElementById("lightbox-prev")!
    .addEventListener("click", () => navigate(-1));
  document
    .getElementById("lightbox-next")!
    .addEventListener("click", () => navigate(1));

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) hide();
  });

  document.addEventListener("keydown", (e) => {
    if (lightbox.classList.contains("hidden")) return;
    if (e.key === "Escape") hide();
    if (e.key === "ArrowLeft") navigate(-1);
    if (e.key === "ArrowRight") navigate(1);
  });

  // Swipe support
  let touchStartX = 0;
  lightbox.addEventListener("touchstart", (e) => {
    touchStartX = e.changedTouches[0].clientX;
  });
  lightbox.addEventListener("touchend", (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) {
      navigate(dx > 0 ? -1 : 1);
    }
  });
</script>
