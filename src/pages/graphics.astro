---
import Layout from "../layouts/Layout.astro";
import Lightbox from "../components/Lightbox.astro";
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

const graphics = (await getCollection("graphics")).sort(
  (a, b) => parseInt(String(b.data.year), 10) - parseInt(String(a.data.year), 10),
);
---

<Layout
  header="Grafika"
  lang="cs"
  description="Přehled grafiky, kterou jsem vytvořil."
>
  {
    graphics.map((project, albumIndex) => (
      <section class="mb-16 flex w-full flex-col" data-album={albumIndex}>
        <div class="border-accent mb-2 flex items-baseline justify-between border-b pb-0.5">
          <h2 class="text-accent font-display text-2xl">{project.data.name}</h2>
          <p class="text-accent text-xl">{project.data.year}</p>
        </div>
        <p
          class="description mb-4 text-lg leading-tight"
          set:html={project.data.description}
        />
        <div class="grid w-full grid-cols-1 items-center-safe justify-center-safe gap-2 sm:grid-cols-3">
          {project.data.images?.map((image, imageIndex) => {
            const desktopWidth =
              image.colspan === 3
                ? "606px"
                : image.colspan === 2
                  ? "402px"
                  : "197px";
            const sizes = `(min-width: 640px) ${desktopWidth}, calc(100vw - 66px)`;
            return (
              <button
                type="button"
                class="lightbox-trigger relative block h-full w-full cursor-pointer overflow-hidden"
                style={`grid-row: auto / span ${image.rowspan}; grid-column: auto / span ${image.colspan}; aspect-ratio: ${image.colspan}/${image.rowspan}`}
                data-album={albumIndex}
                data-index={imageIndex}
                data-src={image.path.src}
              >
                <Picture
                  src={image.path}
                  alt={`${project.data.name} – ${imageIndex + 1}`}
                  class="absolute inset-0 h-full w-full rounded-3xl object-cover"
                  widths={[200, 400, 608, 1216]}
                  sizes={sizes}
                  formats={["avif", "webp"]}
                  loading="lazy"
                />
              </button>
            );
          })}
        </div>
      </section>
    ))
  }

  <Lightbox />
</Layout>
